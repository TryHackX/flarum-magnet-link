{
    "name": "tryhackx/flarum-magnet-link",
    "description": "Secure magnet link integration for Flarum with SHA-256 token protection, SSRF-hardened tracker scraping, live click counters, and an optimized discussion list preview tooltip.",
    "keywords": [
        "flarum",
        "extension",
        "magnet",
        "torrent",
        "bbcode",
        "tracker",
        "scraper",
        "ssrf-protection",
        "token-security",
        "click-counter",
        "tooltip",
        "backfill"
    ],
    "type": "flarum-extension",
    "license": "MIT",
    "authors": [
        {
            "name": "TryHackX",
            "email": "contact@tryhackx.org",
            "homepage": "https://github.com/TryHackX"
        }
    ],
    "support": {
        "issues": "https://github.com/TryHackX/flarum-magnet-link/issues",
        "source": "https://github.com/TryHackX/flarum-magnet-link"
    },
    "require": {
        "php": "^8.2",
        "flarum/core": "^2.0.0-rc.1",
        "s9e/text-formatter": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "TryHackX\\MagnetLink\\": "src/",
            "Scrapeer\\": "src/Scraper/"
        }
    },
    "extra": {
        "flarum-extension": {
            "title": "Magnet Link BBCode",
            "category": "feature",
            "icon": {
                "name": "fas fa-magnet",
                "color": "#e74c3c",
                "backgroundColor": "#1a1a2e"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}